{
  "name": "@boilerplate/backend",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#exceptions/*": "./app/core/exceptions/*.ts",
    "#middleware/*": "./app/core/middleware/*.ts",
    "#providers/*": "./providers/*.ts",
    "#database/*": "./database/*.ts",
    "#start/*": "./start/*.ts",
    "#config/*": "./config/*.ts",
    "#core/*": "./app/core/*.ts",
    "#users/*": "./app/users/*.ts",
    "#auth/*": "./app/auth/*.ts",
    "#admin/*": "./app/admin/*.ts",
    "#common/*": "./app/common/*.ts",
    "#emails/*": "./emails/*.ts",
    "#app/*": "./app/*.ts"
  },
  "exports": {
    ".": "./startServer.ts",
    "./registry": "./.adonisjs/client/registry/index.ts",
    "./data": "./.adonisjs/client/data.d.ts"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "email": "email dev"
  },
  "dependencies": {
    "@adonisjs-community/girouette": "^1.0.0",
    "@adonisjs-community/modules": "^1.1.0",
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/bouncer": "^4.0.0",
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/i18n": "2.2.3",
    "@adonisjs/lucid": "^22.4.1",
    "@adonisjs/mail": "^10.2.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/transmit": "^3.0.1",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@duckdb/node-api": "1.5.2-r.1",
    "@monocle.sh/adonisjs-agent": "^1.1.0",
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "@tuyau/core": "catalog:",
    "@vinejs/vine": "^4.3.0",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "pg": "^8.20.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "8.0.0-next.32",
    "@adonisjs/tsconfig": "2.0.0-next.3",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "5.1.0-next.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@react-email/preview-server": "5.2.5",
    "@swc/core": "1.11.24",
    "@tuyau/utils": "^0.0.9",
    "@types/luxon": "^3.7.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "hot-hook": "0.4.1-next.4",
    "pino-pretty": "^13.1.3",
    "react-email": "^4.3.2",
    "typescript": "catalog:"
  },
  "hotHook": {
    "boundaries": [
      "./app/**/*_controller.ts",
      "./app/middleware/*.ts"
    ]
  }
}
