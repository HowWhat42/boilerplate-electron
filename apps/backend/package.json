{
  "name": "@boilerplate/backend",
  "version": "0.0.1",
  "description": "Boilerplate backend",
  "keywords": [],
  "license": "MIT",
  "files": [
    "dist",
    "ui/dist"
  ],
  "type": "module",
  "types": "./dist/server.d.ts",
  "imports": {
    "#app/*": "./app/*.js",
    "#database/*": "./database/*.ts",
    "#core/*": "./app/core/*.ts"
  },
  "exports": {
    ".": {
      "dev": "./server.ts",
      "default": "./dist/server.js"
    },
    "./data": "./.adonisjs/client/data.d.ts",
    "./registry": "./.adonisjs/client/registry/index.js",
    "./types/*": "./app/core/types/*.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": "./dist/server.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build:server": "tsdown",
    "dev": "tsdown --watch",
    "test": "node --import @poppinss/ts-exec bin/test.ts",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@adonisjs/core": "^7.3.0",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/static": "^2.0.1",
    "@duckdb/node-api": "1.5.1-r.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tuyau/core": "catalog:",
    "@vinejs/vine": "^4.3.0",
    "better-sqlite3": "^12.9.0",
    "kysely": "^0.28.15",
    "kysely-duckdb": "^0.2.0",
    "luxon": "^3.7.2",
    "picocolors": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.1.0",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "tsdown": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
