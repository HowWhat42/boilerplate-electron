{
  "name": "boilerplate",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "scripts": {
    "prepare": "lefthook install || true",
    "dev": "pnpm --filter @boilerplate/desktop dev",
    "format": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "checks": "turbo run lint typecheck",
    "changeset": "changeset",
    "release": "turbo build --filter='./apps/api' && changeset publish"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.11.5",
    "turbo": "^2.9.1"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "lefthook"
    ]
  }
}
